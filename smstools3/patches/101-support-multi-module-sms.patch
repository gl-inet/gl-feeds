From 7fb3da52df0cddecf9f20880634772c2d465a3d3 Mon Sep 17 00:00:00 2001
From: gl-tianwei <tianwei.ma@gl-inet.com>
Date: Thu, 16 Oct 2025 17:15:14 +0800
Subject: [PATCH] smstools3: Support multi-module SMS

---
 src/modeminit.c | 19 ++++++++++++-------
 src/smsd.c      | 32 ++++++++++++++++++++++++++++----
 src/smsd_cfg.c  |  8 ++++++++
 src/smsd_cfg.h  |  2 ++
 4 files changed, 50 insertions(+), 11 deletions(-)

diff --git a/src/modeminit.c b/src/modeminit.c
index 42ff6b4..ea382db 100755
--- a/src/modeminit.c
+++ b/src/modeminit.c
@@ -480,6 +480,11 @@ int write_to_modem(char *command, int timeout, int log_command, int print_error)
     if (log_command)
       writelogfile(LOG_DEBUG, 0, "-> %s",command);
 
+    char send_buf[1024 + 1] = {0};
+    snprintf(send_buf, sizeof(send_buf), "bus#%s|command#%s",DEVICE.bus, command);
+    if (log_command) 
+      writelogfile(LOG_DEBUG, 0, "send_buf:[%s]\n",send_buf);
+
     // 3.1.9:
     if (DEVICE.send_handshake_select)
     {
@@ -487,11 +492,11 @@ int write_to_modem(char *command, int timeout, int log_command, int print_error)
       ssize_t got;
       fd_set writefds;
 
-      n = strlen(command);
+      n = strlen(send_buf);
       while (n > 0)
       {
         bs = (DEVICE.send_delay < 1) ? n : 1;
-        got = write(modem_handle, command + r, bs);
+        got = write(modem_handle, send_buf + r, bs);
         if (got < 0)
         {
           if (errno == EINTR)
@@ -552,7 +557,7 @@ int write_to_modem(char *command, int timeout, int log_command, int print_error)
       // 3.1.5:
       if (DEVICE.send_delay < 1)
       {
-        if ((size_t)write(modem_handle, command, strlen(command)) != strlen(command))
+        if ((size_t)write(modem_handle, send_buf, strlen(send_buf)) != strlen(send_buf))
         {
           writelogfile0(LOG_ERR, 1, tb_sprintf("Could not send string, cause: %s", strerror(errno)));
           alarm_handler0(LOG_ERR, tb);
@@ -564,15 +569,15 @@ int write_to_modem(char *command, int timeout, int log_command, int print_error)
       }
       else
       {
-        for(x=0;(size_t)x<strlen(command);x++)
+        for(x=0;(size_t)x<strlen(send_buf);x++)
         {
-          if (write(modem_handle, command +x, 1) < 1)
+          if (write(modem_handle, send_buf +x, 1) < 1)
           {
             if (print_error)
-              printf("\nCould not send character %c, cause: %s\n",command[x],strerror(errno));
+              printf("\nCould not send character %c, cause: %s\n",send_buf[x],strerror(errno));
             else
             {
-              writelogfile0(LOG_ERR, 1, tb_sprintf("Could not send character %c, cause: %s", command[x], strerror(errno)));
+              writelogfile0(LOG_ERR, 1, tb_sprintf("Could not send character %c, cause: %s", send_buf[x], strerror(errno)));
               alarm_handler0(LOG_ERR, tb);
             }
             return 0;
diff --git a/src/smsd.c b/src/smsd.c
index 37b2e4d..3af75c2 100755
--- a/src/smsd.c
+++ b/src/smsd.c
@@ -218,6 +218,9 @@ char HDR_Voicecall2[SIZE_HEADER] = {};
 const char *HDR_Queue =			"Queue:";	// Msg file input.
 char HDR_Queue2[SIZE_HEADER] = {};
 
+const char *HDR_Bus = "Bus:";// Msg file input.
+char HDR_Bus2[SIZE_HEADER]={};
+
 
 // Headers without translation:
 const char *HDR_SmsdDebug =		"Smsd_debug:";	// For debugging purposes
@@ -1111,7 +1114,8 @@ void readSMSheader(char* filename, /* Filename */
                    int *tp_dcs,
                    int *ping,
                    int *language,
-                   int *language_ext)
+                   int *language_ext,
+                   char *bus)
 {
   FILE* File;
   char line[SIZE_UDH_DATA +256];
@@ -1147,6 +1151,7 @@ void readSMSheader(char* filename, /* Filename */
     *ping = 0;
     *language = -2;
     *language_ext = -2;
+    bus[0] = 0;
 
     // This is global:
     smsd_debug[0] = 0;
@@ -1378,7 +1383,7 @@ void readSMSheader(char* filename, /* Filename */
         if (recursion_level < 1)
           readSMSheader(line, recursion_level +1, to, from, alphabet, with_udh, udh_data, queue, flash,
   	              smsc, report, split, validity, voicecall, hex, replace_msg, macros, system_msg, to_type, retries,
-                      message_reference, reject_duplicates, reply_path, text_is_pdu, sms_class, tp_dcs, ping, language, language_ext);
+                      message_reference, reject_duplicates, reply_path, text_is_pdu, sms_class, tp_dcs, ping, language, language_ext,bus);
       }
       else
       if (test_header(&hlen, line, HDR_Macro, HDR_Macro2))
@@ -1469,6 +1474,12 @@ void readSMSheader(char* filename, /* Filename */
         *language_ext = parse_language_setting(cutspaces(strcpyo(line, line + hlen)));
       else
 #endif
+      if (test_header(&hlen, line, HDR_Bus, HDR_Bus2))
+      {
+          if (strlen(cutspaces(strcpyo(line, line +hlen))) < SIZE_BUS)
+            strncpy(bus, line,SIZE_BUS - 1);
+      }
+      else
       {
         // if the header is unknown, then simply ignore
         ;;
@@ -1897,6 +1908,7 @@ int spool1sms()
   int textlen, with_udh, queue, alphabet, flash, report, split, validity, voicecall, hex, replace_msg,
       system_msg, to_type, retries, message_reference, reject_duplicates, reply_path, text_is_pdu,
       sms_class, tp_dcs, ping, language, language_ext;
+  char bus[SIZE_BUS] = {0};
   char *fail_text = 0;
   int success = 0;
   char cmdline[PATH_MAX+PATH_MAX+32];
@@ -1930,7 +1942,7 @@ int spool1sms()
 
       readSMSheader(filename, 0, to,from,&alphabet,&with_udh,udh_data,queuename,&flash,smsc,&report,&split,
                     &validity, &voicecall, &hex, &replace_msg, NULL, &system_msg, &to_type, &retries,
-                    &message_reference, &reject_duplicates, &reply_path, &text_is_pdu, &sms_class, &tp_dcs, &ping, &language, &language_ext);
+                    &message_reference, &reject_duplicates, &reply_path, &text_is_pdu, &sms_class, &tp_dcs, &ping, &language, &language_ext,bus);
 
       readSMStext(filename, 0, 0, text, &textlen, NULL, NULL);
 
@@ -3540,6 +3552,11 @@ int received2file(char *line1, char *line2, char *filename, int *stored_concaten
         // 3.1.4:
         if (*HDR_Modem2 != '-')
           fprintf(fd, "%s %s\n", get_header_incoming(HDR_Modem, HDR_Modem2), DEVICE.name);
+
+        //gl Adaptable to multi-module
+        if (*HDR_Bus2 != '-')
+          fprintf(fd, "%s %s\n", get_header_incoming(HDR_Bus, HDR_Bus2), DEVICE.bus);
+
         if (DEVICE.number[0])
           if (*HDR_Number2 != '-')
             fprintf(fd, "%s %s\n", get_header_incoming(HDR_Number, HDR_Number2), DEVICE.number);
@@ -4479,6 +4496,7 @@ int send1sms(int* quick, int* errorcounter)
   char *part_start;
   int do_convert;
   char *charconv_notice = 0;
+  char bus[SIZE_BUS] = {0};
 
   time_t start_time; // 3.1.20
 
@@ -4517,7 +4535,13 @@ int send1sms(int* quick, int* errorcounter)
   readSMSheader(filename, 0, to,from,&alphabet,&with_udh,udh_data,provider,&flash,smsc,&report,&split,
                 &validity, &voicecall, &hex, &replace_msg, macros, &system_msg, &to_type, &retries,
                 &message_reference, &reject_duplicates, &reply_path, &text_is_pdu, &sms_class, &tp_dcs,
-                &ping, &language, &language_ext);
+                &ping, &language, &language_ext,bus);
+
+  //gl If the current SMS file does not match the module, exit
+  if (strcmp(DEVICE.bus, bus)) {
+    writelogfile0(LOG_NOTICE, 0, tb_sprintf("The current SMS file and mod bus %s do not match, exit!",bus));
+    return 0;
+  }
 
   // SMSC setting is allowed only if there is smsc set in the config file:
   if (DEVICE.smsc[0] == 0 && !DEVICE.smsc_pdu)
diff --git a/src/smsd_cfg.c b/src/smsd_cfg.c
index 35c1198..d1e98e3 100755
--- a/src/smsd_cfg.c
+++ b/src/smsd_cfg.c
@@ -150,6 +150,7 @@ void initcfg_device(int i)
   int j;
 
   devices[i].name[0] = 0;
+  devices[i].bus[0] = 0;
   devices[i].number[0] = 0;
   devices[i].device[0] = 0;
   devices[i].device_open_retries = 1;
@@ -628,6 +629,13 @@ int readcfg_device(int device, char *device_name)
             continue;
           }
 
+          // .name is set by the program
+          if (!strcasecmp(name, "bus"))
+          {
+            strcpy2(NEWDEVICE.bus, ask_value(NEWDEVICE.name, name, value));
+            continue;
+          }
+          
           // .name is set by the program
 
           if (!strcasecmp(name, "number"))
diff --git a/src/smsd_cfg.h b/src/smsd_cfg.h
index 8ae208d..8d05ff4 100755
--- a/src/smsd_cfg.h
+++ b/src/smsd_cfg.h
@@ -77,6 +77,7 @@ Either version 2 of the License, or (at your option) any later version.
 #define SIZE_SHARED_BUFFER 256
 #define SIZE_FILENAME_PREVIEW 256
 #define SIZE_PB_ENTRY 101
+#define SIZE_BUS 100
 
 #define SIZE_CHECK_MEMORY_BUFFER 512
 // 3.1.12: Changed size from 16384 when CMGL* method is used:
@@ -148,6 +149,7 @@ typedef struct
 typedef struct
 {
   char name[32];		// Name of the modem
+  char bus[SIZE_BUS];     //In multi-module scenarios, specify the bus
   char number[32];              // 3.1.4: SIM card's telephone number.
   char device[PATH_MAX];	// Serial port name
   int device_open_retries;      // 3.1.7: Defines count of retries when opening a device fails.
-- 
2.34.1

