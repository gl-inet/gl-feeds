@@ -841,7 +841,7 @@ int extract_macros(char *buffer, int buffer_size, char *macros)
 int apply_filename_preview(char *filename, char *arg_text, int alphabet)
 {
 /*
-Ģ$ĨčéųėōĮØøÅå Ææ É ÄÖŅÜ§ äöņüā Ī
+ïŋ―$ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ― ïŋ―ïŋ― ïŋ― ïŋ―ïŋ―ïŋ―Ü§ ïŋ―ïŋ―ïŋ―ïŋ―ïŋ― ïŋ―
 LSYeeuioCOoAa Aa E AONUS aonua e
 */
   char *allowed_chars = "-.";
@@ -851,7 +851,7 @@ LSYeeuioCOoAa Aa E AONUS aonua e
     0xC9,
     0xC4, 0xD6, 0xD1, 0xDC, 0xA7,
     0xE4, 0xF6, 0xF1, 0xFC, 0xE0,
-    0xA4, /* 3.1.16beta: ISO character caused warning: 'Ī', */
+    0xA4, /* 3.1.16beta: ISO character caused warning: 'ïŋ―', */
     0x00
   };
   char *replace_to   = "LSYeeuioCOoAaAaEAONUSaonuae";
@@ -3796,6 +3796,31 @@ int receivesms(int* quick, int only1st)
   if (DEVICE.modem_disabled)
     writelogfile(LOG_DEBUG, 0, "receivesms, quick: %i", *quick);
 
+  // Check for dual-SIM standby mode (standby_type == 3)
+  // In dual standby mode, only receive SMS when current SIM slot matches configured slot
+  if (DEVICE.standby_type == 3 && DEVICE.slot[0] != '\0')
+  {
+    int current_slot = get_current_sim_slot();
+    int configured_slot = atoi(DEVICE.slot);
+
+    writelogfile(LOG_DEBUG, 0, "Dual standby mode: current_slot=%d, configured_slot=%d, DEVICE.slot=%s",
+                 current_slot, configured_slot, DEVICE.slot);
+
+    // If unable to determine current slot or doesn't match configured slot, skip SMS reception
+    if (current_slot <= 0)
+    {
+      writelogfile(LOG_NOTICE, 0, "Skipping SMS reception: unable to determine current SIM slot");
+      return 0;
+    }
+
+    if (current_slot != configured_slot)
+    {
+      writelogfile(LOG_NOTICE, 0, "Skipping SMS reception: current slot %d != configured slot %d",
+                   current_slot, configured_slot);
+      return 0;
+    }
+  }
+
   if (*quick==0 && DEVICE.modem_disabled == 0)
   {
     int ret = initialize_modem_receiving();
