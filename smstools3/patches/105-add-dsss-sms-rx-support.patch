Date: Tue, 14 Apr 2026 12:03:56 +0800
Subject: [PATCH] smstools3: add SMS receive handling for DSDS (Dual SIM Single
 Standby) modem

---
 src/modeminit.c | 25 +++++++++++++++++++++++++
 src/modeminit.h |  4 ++++
 src/smsd.c      | 33 +++++++++++++++++++++++++++++----
 src/smsd_cfg.c  | 10 ++++++++++
 src/smsd_cfg.h  |  1 +
 5 files changed, 69 insertions(+), 4 deletions(-)

diff --git a/src/modeminit.c b/src/modeminit.c
index f7ee28e..dfc039a 100755
--- a/src/modeminit.c
+++ b/src/modeminit.c
@@ -2902,3 +2902,28 @@ int try_openmodem()
 
   return result;
 }
+
+// Get current SIM slot for dual-SIM standby mode
+// Returns the current active slot number (1 or 2), or 0 if unable to determine
+int get_current_sim_slot(void)
+{
+  char command[64];
+  char answer[256];
+  char slot_resp[64];
+  int current_slot;
+
+  // Try to get current active SIM slot using AT+QUIMSLOT? command
+  // Response format: \r\n+QUIMSLOT: <slot>\r\n\r\nOK\r\n
+  snprintf(command, sizeof(command), "AT+QUIMSLOT?\r");
+  put_command(command, answer, sizeof(answer), "default", EXPECT_OK_ERROR);
+
+  // Parse response for SIM slot
+  // Response format: +QUIMSLOT: <slot>
+  if (sscanf(answer, "+QUIMSLOT: %d", &current_slot) == 1)
+  {
+    writelogfile(LOG_DEBUG, 0, "Current active SIM slot: %d", current_slot);
+    return current_slot;
+  }
+
+  return 0;
+}
diff --git a/src/modeminit.h b/src/modeminit.h
index 8c688c0..c6f360f 100755
--- a/src/modeminit.h
+++ b/src/modeminit.h
@@ -75,4 +75,8 @@ int wait_network_registration(int waitnetwork_errorsleeptime, int retry_count);
 int try_closemodem(int force);
 int try_openmodem();
 
+// Get current SIM slot for dual-SIM standby mode
+// Returns the current active slot number (1 or 2), or 0 if unable to determine
+int get_current_sim_slot(void);
+
 #endif
