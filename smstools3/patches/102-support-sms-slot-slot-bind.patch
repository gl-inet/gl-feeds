     if (log_command)
       writelogfile(LOG_DEBUG, 0, "-> %s",command);
 
+#define DEFAULT_SLOT "1"
+
     char send_buf[1024 + 1] = {0};
-    snprintf(send_buf, sizeof(send_buf), "bus#%s|command#%s",DEVICE.bus, command);
+    if (strlen(DEVICE.slot) > 0)
+      snprintf(send_buf, sizeof(send_buf), "bus#%s|slot#%s|command#%s",DEVICE.bus,DEVICE.slot,command);
+    else
+      snprintf(send_buf, sizeof(send_buf), "bus#%s|slot#%s|command#%s",DEVICE.bus,DEFAULT_SLOT,command);
+
     if (log_command) 
       writelogfile(LOG_DEBUG, 0, "send_buf:[%s]\n",send_buf);
 
@@ -1559,6 +1565,16 @@ int initmodem(char *new_smsc, int receiving)
 
   // -----------------------------------------------------------------------------------------------
   writelogfile(LOG_INFO, 0, "Checking if modem is ready");
+    //add by gl
+  snprintf(command, sizeof(command), "AT+CPIN?\r\n");
+  for (int i = 0; i < 3;i++) {
+    put_command(command, answer, sizeof(answer), "default", "READY");
+    if (NULL == strstr(answer,"READY") &&  i == 2) {
+      writelogfile(LOG_DEBUG, 0, "Curr bus %s sim card not present, exiting SMS reception check\n",DEVICE.bus);
+      return 8;
+    }
+    t_sleep(1);
+  }
 
   // 3.1.16beta: If wakeup_init is defined, send it to the modem:
   if (DEVICE.wakeup_init[0])
