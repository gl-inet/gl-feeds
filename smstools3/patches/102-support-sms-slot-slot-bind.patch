   }
 }
 
+
+static void trim_str(char *str)
+{
+    if (!str) return;
+
+    char *start = str;
+    while (*start && isspace((unsigned char)*start))
+        start++;
+
+    char *end = start + strlen(start);
+    while (end > start && isspace((unsigned char)*(end - 1)))
+        end--;
+
+    *end = '\0';
+
+    if (start != str)
+        memmove(str, start, end - start + 1);
+}
+
