+// SlimStatusForJSON reduces Status JSON size for embedded routers.
+func SlimStatusForJSON(st *Status) {
+	if st == nil {
+		return
+	}
+	trimmed := make(map[key.NodePublic]exitNodePeerJSON)
+	for k, ps := range st.Peer {
+		if ps == nil || !ps.ExitNodeOption {
+			continue
+		}
+		trimmed[k] = peerToExitNodePeerJSON(ps)
+	}
+	st.slimPeers = trimmed
+	st.Peer = nil
+}
+
+func firstIPv4Addr(addrs []netip.Addr) []netip.Addr {
+	for _, a := range addrs {
+		if a.Is4() {
+			return []netip.Addr{a}
+		}
+	}
+	return nil
+}
+
+func firstIPv4Prefix(prefixes []netip.Prefix) []netip.Prefix {
+	for _, p := range prefixes {
+		if p.Addr().Is4() {
+			return []netip.Prefix{p}
+		}
+	}
+	return nil
+}
+
+func peerToExitNodePeerJSON(ps *PeerStatus) exitNodePeerJSON {
+	out := exitNodePeerJSON{
+		PublicKey:      ps.PublicKey,
+		DNSName:        ps.DNSName,
+		TailscaleIPs:   firstIPv4Addr(ps.TailscaleIPs),
+		ExitNodeOption: ps.ExitNodeOption,
+	}
+	if ps.Tags != nil && !ps.Tags.IsNil() {
+		out.Tags = ps.Tags
+	}
+	if ps.Location != nil {
+		out.Location = &exitNodeLocationJSON{
+			Country: ps.Location.Country,
+			City:    ps.Location.City,
+		}
+	}
+	return out
+}
+
+func (s *Status) MarshalJSON() ([]byte, error) {
+	if s.slimPeers == nil {
+		type statusAlias Status
+		return json.Marshal((*statusAlias)(s))
+	}
+	out := struct {
+		Version        string                                 `json:"Version,omitempty"`
+		TUN            bool                                   `json:"TUN,omitempty"`
+		BackendState   string                                 `json:"BackendState"`
+		HaveNodeKey    bool                                   `json:"HaveNodeKey,omitempty"`
+		AuthURL        string                                 `json:"AuthURL,omitempty"`
+		TailscaleIPs   []netip.Addr                           `json:"TailscaleIPs,omitempty"`
+		Self           *PeerStatus                            `json:"Self,omitempty"`
+		ExitNodeStatus *exitNodeStatusJSON                    `json:"ExitNodeStatus,omitempty"`
+		Health         []string                               `json:"Health,omitempty"`
+		MagicDNSSuffix string                                 `json:"MagicDNSSuffix,omitempty"`
+		CurrentTailnet *TailnetStatus                         `json:"CurrentTailnet,omitempty"`
+		CertDomains    []string                               `json:"CertDomains,omitempty"`
+		Peer           map[key.NodePublic]exitNodePeerJSON    `json:"Peer,omitempty"`
+		User           map[tailcfg.UserID]tailcfg.UserProfile `json:"User,omitempty"`
+		ClientVersion  *tailcfg.ClientVersion                 `json:"ClientVersion,omitempty"`
+	}{
+		Version: s.Version, TUN: s.TUN, BackendState: s.BackendState,
+		HaveNodeKey: s.HaveNodeKey, AuthURL: s.AuthURL,
+		TailscaleIPs: firstIPv4Addr(s.TailscaleIPs), Self: s.Self,
+		Health: s.Health, MagicDNSSuffix: s.MagicDNSSuffix,
+		CurrentTailnet: s.CurrentTailnet, CertDomains: s.CertDomains,
+		Peer: s.slimPeers, User: s.User, ClientVersion: s.ClientVersion,
+	}
+	if s.ExitNodeStatus != nil {
+		out.ExitNodeStatus = &exitNodeStatusJSON{TailscaleIPs: firstIPv4Prefix(s.ExitNodeStatus.TailscaleIPs)}
+	}
+	return json.Marshal(out)
+}
