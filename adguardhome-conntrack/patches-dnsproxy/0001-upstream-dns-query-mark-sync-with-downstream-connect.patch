+// MarkProvider provides connection marks for sockets.
+type MarkProvider interface {
+	// GetMark returns the mark to be set on the socket.
+	GetMark() uint32
+}
+
+var markProvider MarkProvider
+
+// SetMarkProvider sets the global mark provider.
+func SetMarkProvider(p MarkProvider) {
+	markProvider = p
+}
+
+// GetMarkProvider returns the global mark provider.
+func GetMarkProvider() MarkProvider {
+	return markProvider
+}
+
 // Network is a network type for use in [Resolver]'s methods.
 type Network = string
 
@@ -107,6 +126,18 @@ func NewDialContext(timeout time.Duration, l *slog.Logger, addrs ...string) (h D
 
 	dialer := &net.Dialer{
 		Timeout: timeout,
+		Control: func(network string, address string, c syscall.RawConn) error {
+			var operr error
+			if err := c.Control(func(fd uintptr) {
+				if markProvider != nil {
+					mark := markProvider.GetMark()
+					operr = syscall.SetsockoptInt(int(fd), syscall.SOL_SOCKET, syscall.SO_MARK, int(mark))
+				}
+			}); err != nil {
+				return err
+			}
+			return operr
+		},
 	}
 
 	return func(ctx context.Context, network Network, _ string) (conn net.Conn, err error) {
@@ -128,7 +159,11 @@ func NewDialContext(timeout time.Duration, l *slog.Logger, addrs ...string) (h D
 				continue
 			}
 
-			a.DebugContext(ctx, "connection succeeded", "elapsed", elapsed)
+			if markProvider != nil {
+				a.DebugContext(ctx, "connection succeeded", "mark", markProvider.GetMark(), "elapsed", elapsed)
+			} else {
+				a.DebugContext(ctx, "connection succeeded", "elapsed", elapsed)
+			}
 
 			return conn, nil
 		}
