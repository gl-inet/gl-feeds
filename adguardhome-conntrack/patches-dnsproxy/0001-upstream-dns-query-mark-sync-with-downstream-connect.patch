diff --git a/internal/bootstrap/bootstrap_mark_linux.go b/internal/bootstrap/bootstrap_mark_linux.go
new file mode 100644
index 0000000..42bb917
--- /dev/null
+++ b/internal/bootstrap/bootstrap_mark_linux.go
@@ -0,0 +1,19 @@
+//go:build linux
+
+package bootstrap
+
+import (
+	"syscall"
+)
+
+// setConnMarkRaw sets SO_MARK on the socket represented by c.
+// It must return an error if setting the mark fails.
+func setConnMarkRaw(c syscall.RawConn, mark uint32) error {
+	var operr error
+	if err := c.Control(func(fd uintptr) {
+		operr = syscall.SetsockoptInt(int(fd), syscall.SOL_SOCKET, syscall.SO_MARK, int(mark))
+	}); err != nil {
+		return err
+	}
+	return operr
+}
