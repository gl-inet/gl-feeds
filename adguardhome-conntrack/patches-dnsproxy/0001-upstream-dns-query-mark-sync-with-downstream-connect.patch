 )
 
+// Context utilities for per-request connection mark.
+type ctxKey int
+
+// markKey is the private key type for storing connection mark in context.
+const markKey ctxKey = iota
+
+// WithMark returns a new context that carries the connection mark.
+func WithMark(ctx context.Context, mark uint32) context.Context {
+	return context.WithValue(ctx, markKey, mark)
+}
+
+// MarkFromContext extracts the connection mark from ctx if present.
+func MarkFromContext(ctx context.Context) (uint32, bool) {
+	v := ctx.Value(markKey)
+	if v == nil {
+		return 0, false
+	}
+	m, ok := v.(uint32)
+	return m, ok
+}
+
+// sysCaller is implemented by net.Conn/net.PacketConn types that expose
+// access to the underlying file descriptor via SyscallConn.
+type sysCaller interface {
+	SyscallConn() (syscall.RawConn, error)
+}
+
+// SetConnMark sets SO_MARK on a connection.  Even if mark is 0, it explicitly
+// clears the mark on Linux.  On non-Linux platforms this is a no-op via stub.
+func SetConnMark(conn net.Conn, mark uint32) error {
+	sc, ok := conn.(sysCaller)
+	if !ok {
+		return errors.Error("connection does not support SyscallConn")
+	}
+	rc, err := sc.SyscallConn()
+	if err != nil {
+		return err
+	}
+	return setConnMarkRaw(rc, mark)
+}
+
+// SetPacketMark sets SO_MARK on a packet connection.  Even if mark is 0, it
+// explicitly clears the mark on Linux.  On non-Linux platforms this is a no-op
+// via stub.
+func SetPacketMark(pc net.PacketConn, mark uint32) error {
+	sc, ok := pc.(sysCaller)
+	if !ok {
+		return errors.Error("packet conn does not support SyscallConn")
+	}
+	rc, err := sc.SyscallConn()
+	if err != nil {
+		return err
+	}
+	return setConnMarkRaw(rc, mark)
+}
+
 // Network is a network type for use in [Resolver]'s methods.
 type Network = string
 
