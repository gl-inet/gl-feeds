 		}
 	}
 
-	dialer := &net.Dialer{
-		Timeout: timeout,
-	}
-
 	return func(ctx context.Context, network Network, _ string) (conn net.Conn, err error) {
+		// Extract per-request mark from context.
+		mark, hasMark := MarkFromContext(ctx)
 		var errs []error
 
 		// Return first succeeded connection.  Note that we're using addrs
@@ -119,7 +174,19 @@ func NewDialContext(timeout time.Duration, l *slog.Logger, addrs ...string) (h D
 			a.DebugContext(ctx, "dialing", "idx", i+1, "total", addrLen)
 
 			start := time.Now()
-			conn, err = dialer.DialContext(ctx, network, addr)
+			// Create a dialer per attempt so that Control can capture the current mark.
+			d := &net.Dialer{
+				Timeout: timeout,
+				Control: func(_ string, _ string, c syscall.RawConn) error {
+					if !hasMark {
+						return nil
+					}
+					// Set SO_MARK strictly; platform-specific implementation.
+					return setConnMarkRaw(c, mark)
+				},
+			}
+
+			conn, err = d.DialContext(ctx, network, addr)
 			elapsed := time.Since(start)
 			if err != nil {
 				a.DebugContext(ctx, "connection failed", "elapsed", elapsed, slogutil.KeyError, err)
@@ -128,7 +195,11 @@ func NewDialContext(timeout time.Duration, l *slog.Logger, addrs ...string) (h D
 				continue
 			}
 
-			a.DebugContext(ctx, "connection succeeded", "elapsed", elapsed)
+			if hasMark {
+				a.DebugContext(ctx, "connection succeeded", "mark", mark, "elapsed", elapsed)
+			} else {
+				a.DebugContext(ctx, "connection succeeded", "elapsed", elapsed)
+			}
 
