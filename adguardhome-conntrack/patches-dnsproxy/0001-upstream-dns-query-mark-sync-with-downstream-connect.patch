+
+import (
+	"github.com/AdguardTeam/golibs/errors"
+	"syscall"
+)
+
+// setConnMarkRaw is a no-op on non-Linux platforms.
+// It returns nil to avoid failing on unsupported systems while keeping API parity.
+func setConnMarkRaw(_ syscall.RawConn, _ uint32) error {
+    return nil
+}
