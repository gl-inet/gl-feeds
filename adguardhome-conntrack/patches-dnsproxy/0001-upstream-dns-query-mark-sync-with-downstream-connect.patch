+
+// ExchangeContext calls ExchangeContext on u if it implements
+// UpstreamWithContext. Otherwise, it falls back to the legacy Exchange method.
+func ExchangeContext(u Upstream, ctx context.Context, req *dns.Msg) (*dns.Msg, error) {
+    if cu, ok := any(u).(UpstreamWithContext); ok {
+        return cu.ExchangeContext(ctx, req)
+    }
+    return u.Exchange(req)
+}
