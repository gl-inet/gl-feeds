+// UpstreamWithContext is an optional extension that allows passing a context
+// (including per-request connection mark) through the exchange pipeline.
+// Implementations should honor ctx for deadlines/cancellation and for
+// context-propagated metadata such as SO_MARK.
+type UpstreamWithContext interface {
+    ExchangeContext(ctx context.Context, req *dns.Msg) (resp *dns.Msg, err error)
