+
+// newDNSCryptDialerInitializer creates a dialer initializer specifically for DNSCrypt
+// that parses the stamp to extract the actual server address.
+func newDNSCryptDialerInitializer(u *url.URL, opts *Options) DialerInitializer {
+	var l *slog.Logger
+	if opts.Logger != nil {
+		l = opts.Logger.With(slogutil.KeyPrefix, "bootstrap")
+	} else {
+		l = slog.Default()
+	}
+
+	return func() (h bootstrap.DialHandler, err error) {
+		// Parse the DNSCrypt stamp to get the actual server address
+		stamp, parseErr := dnsstamps.NewServerStampFromString(u.String())
+		if parseErr != nil {
+			return nil, fmt.Errorf("parsing dnscrypt stamp: %w", parseErr)
+		}
+
+		// Use the parsed server address for dialing
+		serverAddr := stamp.ServerAddrStr
+		if serverAddr == "" {
+			return nil, fmt.Errorf("empty server address in dnscrypt stamp")
+		}
+
+		// Create a simple dialer for the resolved address
+		return bootstrap.NewDialContext(opts.Timeout, l, serverAddr), nil
+	}
+}
