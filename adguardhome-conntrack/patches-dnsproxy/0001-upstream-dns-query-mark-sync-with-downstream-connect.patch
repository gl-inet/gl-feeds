@@ -0,0 +1,52 @@
+package proxy
+
+import (
+	"sync"
+
+	"github.com/AdguardTeam/dnsproxy/internal/bootstrap"
+)
+
+// dnsContextMarkProvider provides connection marks from DNSContext.
+type dnsContextMarkProvider struct {
+	sync.RWMutex
+	dctx *DNSContext
+}
+
+// newDNSContextMarkProvider creates a new dnsContextMarkProvider.
+func newDNSContextMarkProvider() *dnsContextMarkProvider {
+	return &dnsContextMarkProvider{}
+}
+
+// GetMark implements the bootstrap.MarkProvider interface for dnsContextMarkProvider.
+func (p *dnsContextMarkProvider) GetMark() uint32 {
+	p.RLock()
+	defer p.RUnlock()
+
+	if p.dctx == nil {
+		return 0
+	}
+
+	return p.dctx.ConnectionMark
+}
+
+// SetDNSContext sets the DNSContext for the provider.
+func (p *dnsContextMarkProvider) SetDNSContext(dctx *DNSContext) {
+	p.Lock()
+	defer p.Unlock()
+
+	p.dctx = dctx
+}
+
+// ClearDNSContext clears the DNSContext from the provider.
+func (p *dnsContextMarkProvider) ClearDNSContext() {
+	p.Lock()
+	defer p.Unlock()
+
+	p.dctx = nil
+}
+
+// initMarkProvider initializes the mark provider for a proxy instance.
+func (p *Proxy) initMarkProvider() {
+	p.markProvider = newDNSContextMarkProvider()
+	bootstrap.SetMarkProvider(p.markProvider)
+}
