+
+	// EnableConntrack enables synchronization of connection marks between downstream DNS
+	// queries and their corresponding upstream queries. When enabled, the proxy will:
+	// 1. Query the conntrack subsystem to get the mark of the incoming DNS query connection
+	// 2. Set this mark on the socket used for the upstream DNS query
+	// This allows for policy-based routing of DNS queries based on their source.
+	// When disabled, no connection marks will be queried or set.
+	EnableConntrack bool
 }
 
