diff --git a/proxy/conntrack_linux.go b/proxy/conntrack_linux.go
new file mode 100644
index 0000000..95e120c
--- /dev/null
+++ b/proxy/conntrack_linux.go
@@ -0,0 +1,123 @@
+//go:build linux
+
+package proxy
+
+import (
+	"fmt"
+	"log"
+	"net"
+	"sync"
+	"syscall"
+
+	ct "github.com/florianl/go-conntrack"
+)
+
+var (
+	nfct       *ct.Nfct
+	nfctOnce   sync.Once
+	nfctError  error
+	nfctMutex  sync.Mutex // protects access to nfct
+)
+
+// initConntrack initializes the conntrack connection
+func initConntrack() error {
+	nfctOnce.Do(func() {
+		// create a logger for debugging
+		logger := log.New(log.Writer(), "conntrack: ", log.LstdFlags)
+		var err error
+		nfct, err = ct.Open(&ct.Config{
+			Logger: logger,
+		})
+		if err != nil {
+			nfctError = fmt.Errorf("failed to open conntrack: %v", err)
+		}
+	})
+	return nfctError
+}
+
+// getIPv4 returns the IPv4 address if the IP is IPv4 or IPv4-mapped IPv6
+func getIPv4(ip net.IP) net.IP {
+	if v4 := ip.To4(); v4 != nil {
+		return v4
+	}
+	return nil
+}
+
+// getConnMark is a helper function that returns the mark of a connection.
+// When EnableConntrack is true, it returns an error if mark retrieval fails.
+func (p *Proxy) getConnMark(src, dst net.IP, srcPort, dstPort uint16, proto uint8) (uint32, error) {
+	if !p.EnableConntrack {
+		return 0, nil
+	}
+
+	if err := initConntrack(); err != nil {
+		log.Printf("Failed to init conntrack: %v", err)
+		return 0, fmt.Errorf("conntrack initialization failed: %w", err)
+	}
+
+	nfctMutex.Lock()
+	defer nfctMutex.Unlock()
+
+	// if it's an IPv6 any address (::), try to use the peer's address family
+	if src.Equal(net.IPv6unspecified) && getIPv4(dst) != nil {
+		src = net.IPv4zero // use 0.0.0.0
+	}
+
+	// determine address family
+	family := ct.IPv6
+	if getIPv4(dst) != nil {
+		family = ct.IPv4
+	}
+
+	// create query conditions
+	match := ct.Con{
+		Origin: &ct.IPTuple{
+			Src: &src,
+			Dst: &dst,
+			Proto: &ct.ProtoTuple{
+				Number:  uint8ptr(proto),
+				SrcPort: uint16ptr(srcPort),
+				DstPort: uint16ptr(dstPort),
+			},
+		},
+	}
+
+	// query connection
+	conns, err := nfct.Get(ct.Conntrack, family, match)
+	if err != nil {
+		log.Printf("Failed to get connection: %v", err)
+		return 0, fmt.Errorf("conntrack query failed: %w", err)
+	}
+
+	// if connection is found, return its mark
+	if len(conns) > 0 && conns[0].Mark != nil {
+		return *conns[0].Mark, nil
+	}
+
+	// Connection not found in conntrack, this could indicate:
+	// 1. Connection has already been closed
+	// 2. Connection tracking is not working properly
+	// 3. Connection was not tracked for some reason
+	// In strict mode, we must fail to prevent policy bypass
+	log.Printf("Connection not found in conntrack: %s:%d -> %s:%d proto=%d", src, srcPort, dst, dstPort, proto)
+	return 0, fmt.Errorf("connection not found in conntrack table")
+}
+
+// GetConnectionMark returns the mark of a TCP connection.
+func (p *Proxy) GetConnectionMark(localAddr, remoteAddr *net.TCPAddr) (uint32, error) {
+	return p.getConnMark(localAddr.IP, remoteAddr.IP, uint16(localAddr.Port), uint16(remoteAddr.Port), syscall.IPPROTO_TCP)
+}
+
+// GetUDPConnectionMark returns the mark of a UDP connection.
+func (p *Proxy) GetUDPConnectionMark(localAddr, remoteAddr *net.UDPAddr) (uint32, error) {
+	return p.getConnMark(localAddr.IP, remoteAddr.IP, uint16(localAddr.Port), uint16(remoteAddr.Port), syscall.IPPROTO_UDP)
+}
+
+// Helper functions to create pointers to primitive types
+func uint8ptr(v uint8) *uint8 {
+	return &v
+}
+
+func uint16ptr(v uint16) *uint16 {
+	return &v
+}
