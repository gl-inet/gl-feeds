From 655ab904f5723f57117e7507d524c29a95950bac Mon Sep 17 00:00:00 2001
From: Jianhui Zhao <zhaojh329@gmail.com>
Date: Thu, 30 Apr 2026 10:28:47 +0800
Subject: [PATCH] feat(file): make dir iterator tolerate missing directories

Do not return an error when the target directory does not exist.
This lets for-iteration finish gracefully instead of crashing when callers
skip an explicit directory existence check.
Behavior is now safer and more fault-tolerant for common usage paths.

Signed-off-by: Jianhui Zhao <zhaojh329@gmail.com>
---
 file.c | 2 --
 1 file changed, 2 deletions(-)

diff --git a/file.c b/file.c
index 70d2d57..13a20d7 100644
--- a/file.c
+++ b/file.c
@@ -341,8 +341,6 @@ static int lua_file_dir(lua_State *L)
     lua_setmetatable(L, -2);
 
     *d = opendir(path);
-    if (!*d)
-        return luaL_error(L, "%s", strerror(errno));
 
     lua_rotate(L, 1, 1);
 
-- 
2.34.1

