From 93ddfe3f2f2d1c682b8390f688e2a1120b49ed79 Mon Sep 17 00:00:00 2001
From: Jianhui Zhao <zhaojh329@gmail.com>
Date: Thu, 3 Apr 2025 17:19:30 +0800
Subject: [PATCH 1/6] fix(ssl): forgot stop `io` watcher on `lua_ssl_free`

```
Assertion failed: ("libev: I/O watcher with invalid fd found in epoll_ctl", errno != EBADF && errno != ELOOP && errno != EINVAL) (ev_epoll.c: epoll_modify: 134)
```

Signed-off-by: Jianhui Zhao <zhaojh329@gmail.com>
---
 ssl.c | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/ssl.c b/ssl.c
index 2f8ba0e..062959b 100644
--- a/ssl.c
+++ b/ssl.c
@@ -80,10 +80,16 @@ static void ev_io_cb(struct ev_loop *loop, ev_io *w, int revents)
 static int lua_ssl_free(lua_State *L)
 {
     struct eco_ssl_session *s = luaL_checkudata(L, 1, ECO_SSL_MT);
+    struct ev_loop *loop;
 
     if (!s->ssl)
         return 0;
 
+    loop = s->ctx->eco->loop;
+
+    ev_timer_stop(loop, &s->tmr);
+    ev_io_stop(loop, &s->io);
+
     ssl_session_free(s->ssl);
     s->ssl = NULL;
 
-- 
