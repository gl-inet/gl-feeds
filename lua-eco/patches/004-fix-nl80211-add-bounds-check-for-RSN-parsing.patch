From 37de893f402749c16cc90797f84824fde16c7142 Mon Sep 17 00:00:00 2001
From: Jianhui Zhao <zhaojh329@gmail.com>
Date: Mon, 29 Dec 2025 11:42:14 +0800
Subject: [PATCH] fix(nl80211): add bounds check for RSN parsing

Prevent crash when parsing malformed RSN data from certain APs by
checking the minimum length before accessing the version field.

Signed-off-by: Jianhui Zhao <zhaojh329@gmail.com>
---
 nl80211.lua | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/nl80211.lua b/nl80211.lua
index a737509..aa00f1f 100644
--- a/nl80211.lua
+++ b/nl80211.lua
@@ -550,6 +550,10 @@ local function parse_cipher(data)
 end
 
 local function parse_rsn(data, defcipher, defauth)
+    if #data < 2 then
+        return
+    end
+
     local res = {
         version = str_byte(data, 1) | str_byte(data, 2) << 8,
         group_cipher = defcipher,
-- 
2.34.1

