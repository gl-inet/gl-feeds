From 904c63e4113148d65ecc13998561d4dbde9bee48 Mon Sep 17 00:00:00 2001
From: Jianhui Zhao <zhaojh329@gmail.com>
Date: Wed, 22 Apr 2026 09:13:29 +0800
Subject: [PATCH] fix(nl80211): Fix crash in `parse_bss_ie`
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

```
nl80211.lua:600: bad argument #2 to ‘unpack' (data string to0 short)
```

Signed-off-by: Jianhui Zhao <zhaojh329@gmail.com>
---
 nl80211.lua | 10 +++++++---
 1 file changed, 7 insertions(+), 3 deletions(-)

diff --git a/nl80211.lua b/nl80211.lua
index a22c53a..f58cee9 100644
--- a/nl80211.lua
+++ b/nl80211.lua
@@ -597,11 +597,15 @@ local function parse_bss_ie(info, data, keep_elems)
     local elems = {}
 
     while #data > 1 do
-        local typ, elem_data, i = string.unpack('Bs1', data)
-        if not typ then
+        local typ = str_byte(data, 1)
+        local elem_len = str_byte(data, 2)
+
+        if #data < 2 + elem_len then
             break
         end
 
+        local elem_data = data:sub(3, 2 + elem_len)
+
         if typ == M.WLAN_EID_SSID or typ == M.WLAN_EID_MESH_ID then
             info.ssid = elem_data
         elseif typ == M.WLAN_EID_RSN then
@@ -619,7 +623,7 @@ local function parse_bss_ie(info, data, keep_elems)
             elem[#elem + 1] = elem_data
         end
 
-        data = data:sub(i)
+        data = data:sub(3 + elem_len)
     end
 
     if keep_elems then
-- 
2.34.1

