From: Jianhui Zhao <zhaojh329@gmail.com>
Date: Fri, 24 Oct 2025 15:54:54 +0800
Subject: [PATCH 7/7] feat(nl80211): Add IE support to scan requests

```
local oui = '\x94\x83\xc4\x01'
local ie = string.pack('Bs1', nl80211.WLAN_EID_VENDOR_SPECIFIC, oui)
local ok, err = nl80211.scan('trigger', { ifname = 'wlan0', ssids = { '' }, ie = ie })
```
---
 nl80211.lua | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/nl80211.lua b/nl80211.lua
index 3bdd1f7..ca1f523 100644
--- a/nl80211.lua
+++ b/nl80211.lua
@@ -757,6 +757,10 @@ local function nl80211_scan(sock, msg, action, cmd, params)
             end
             msg:put_attr_nest_end()
         end
+
+        if params.ie then
+            msg:put_attr(nl80211.ATTR_IE, params.ie)
+        end
     end
 
     local ok, err = sock:send(msg)
